{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "declaration": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": false,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "paths": {
      "@skalfa/skalfa-app-core": [
        "../skalfa-app-core/dist/index.d.ts",
        "./node_modules/@skalfa/skalfa-app-core/dist/index.d.ts"
      ],
      "@contexts": [
        "./src/contexts-mock.ts"
      ],
      "@utils": [
        "../skalfa-app-core/dist",
        "../skalfa-app-core/dist/index.d.ts",
        "./node_modules/@skalfa/skalfa-app-core/dist"
      ],
      "@utils/*": [
        "../skalfa-app-core/dist/*",
        "./node_modules/@skalfa/skalfa-app-core/dist/*"
      ],
      "@components": ["./src/index.ts"],
      "@components/*": ["./src/*"],
      "react": [
        "../skalfa-app/node_modules/react",
        "./node_modules/react"
      ],
      "@types/react": [
        "../skalfa-app/node_modules/@types/react",
        "./node_modules/@types/react"
      ],
      "@types/react-dom": [
        "../skalfa-app/node_modules/@types/react-dom",
        "./node_modules/@types/react-dom"
      ]
    }
  },
  "include": ["src/**/*", "src/.supervision"]
}
